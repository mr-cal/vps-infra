# Alert by email when root disk usage crosses a threshold.
# Runs every 15 minutes so a fast-filling disk (e.g. runaway logs, dangling
# images) is caught within minutes instead of silently cascading into a
# service outage/data-loss incident, as happened on 2026-07-23.
*/15 * * * * root /opt/vps-infra/backups/check_disk_space.sh >> /var/log/disk-space-check.log 2>&1
