# Env file for the continuous LLM evaluation worker
# (docker-compose.llm-evaluate.yml).
# Copy to /opt/vps-infra/llm-evaluate.env and fill in real values.
# SECURITY: chmod 600 /opt/vps-infra/llm-evaluate.env
#
# Deliberately does NOT include DATABASE_URL — the evaluate worker only
# ever talks to craft-dashboard over HTTP (see /api/eval/next, /api/eval/result),
# never the database directly.

# Base URL of the craft-dashboard app, reachable over the shared vps-net
# podman network by its compose service name (see docker-compose.craft-dashboard.yml).
EVAL_CLIENT_SERVER=http://craft-dashboard:8000

# Eval API bearer token — must match EVAL_API_TOKEN in the main craft-dashboard .env.
EVAL_API_TOKEN=

# OpenRouter API key — required even when using the local LLM backend for
# generation, since summary embeddings always use OpenRouter.
OPENROUTER_API_KEY=

# Log level for the worker (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
