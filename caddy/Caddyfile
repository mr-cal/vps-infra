# Caddy auto-obtains and renews TLS certificates for all listed domains.

{
	# Explicitly use Let's Encrypt production CA.
	acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# craft-dashboard — reverse proxy to the FastAPI app
craft-dashboard.name {
	reverse_proxy craft-dashboard:8000
}

# egg-calculator — static site served from the git submodule
eggcalculator.com {
	root * /srv/egg-calculator/src
	file_server
}

# Redirect www to apex
www.eggcalculator.com {
	redir https://eggcalculator.com{uri} permanent
}

