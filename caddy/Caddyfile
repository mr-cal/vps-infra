# Caddy auto-obtains and renews TLS certificates for all listed domains.

{
	# Explicitly use Let's Encrypt production CA.
	acme_ca https://acme-v02.api.letsencrypt.org/directory
}

# craft-dashboard — reverse proxy to the FastAPI app
craft-dashboard.name {
	reverse_proxy craft-dashboard:8000
}

# egg-calculator — static site served from the git submodule
eggcalculator.com {
	root * /srv/egg-calculator/src
	file_server
}

# Redirect www to apex
www.eggcalculator.com {
	redir https://eggcalculator.com{uri} permanent
}

# flashcandy — static site served from the git submodule
flashcandy.us {
	root * /srv/flashcandy/public
	file_server
}

# Redirect www to apex
www.flashcandy.us {
	redir https://flashcandy.us{uri} permanent
}

# pcbisolation — Hugo static site
pcbisolation.com {
	root * /srv/pcbisolation
	file_server

	# WordPress image redirects (generated by scripts/generate_image_redirects.py)
	import /etc/caddy/pcbisolation-image-redirects.caddy
}

# Redirect www to apex
www.pcbisolation.com {
	redir https://pcbisolation.com{uri} permanent
}

# Remark42 self-hosted comments
comments.pcbisolation.com {
	reverse_proxy vps-infra_remark42_1:8080
}

