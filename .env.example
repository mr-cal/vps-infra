# Production environment for the VPS.
# Copy to /opt/vps-infra/.env and fill in real values.
# SECURITY: chmod 600 /opt/vps-infra/.env

# PostgreSQL connection string.
# The password here must match the DB_PASSWORD GitHub Actions secret.
DATABASE_URL=postgresql+asyncpg://craft_dashboard:<password>@postgres/craft_dashboard

# GitHub fine-grained token with read access to public repos
GITHUB_TOKEN=

# OpenRouter API key for server-side LLM evaluation
OPENROUTER_API_KEY=

# Admin bearer token for protected endpoints
ADMIN_TOKEN=

# Eval API bearer token for /api/eval/* endpoints (pull-based evaluation)
EVAL_API_TOKEN=

# Toggle server-side LLM evaluation (set to false to disable run_llm evaluate)
ENABLE_SERVER_EVAL=true

# FastAPI debug mode (shows tracebacks in the browser)
DEBUG=false

# Log level for scripts (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
