# PostgreSQL password for the craft-dashboard database.
DB_PASSWORD=

# craft-dashboard application secrets — see craft-dashboard/.env.example
# for the full list. At minimum, set these for production:
DATABASE_URL=postgresql+asyncpg://craft_dashboard:${DB_PASSWORD}@postgres/craft_dashboard
GITHUB_TOKEN=
OPENROUTER_API_KEY=
ADMIN_TOKEN=
EVAL_API_TOKEN=
ENABLE_SERVER_EVAL=true
DEBUG=false
LOG_LEVEL=INFO
